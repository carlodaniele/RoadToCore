# RoadToCode core settings
APP_HOST=0.0.0.0
APP_PORT=8080
ENV_VALIDATION_STRICT=

# Security
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_TOKEN=

# Delivery
ROADTOCODE_OUTBOX_DIR=./outbox
ROADTOCODE_ASSETS_DIR=./outbox/assets

# Delivery execution
DELIVERY_AUTORUN=false
DELIVERY_RETRIES=2
DELIVERY_RETRY_BACKOFF_SECONDS=2.0

# WordPress delivery
DELIVERY_WORDPRESS_ENABLED=false
DELIVERY_WORDPRESS_ENDPOINT=
DELIVERY_WORDPRESS_USERNAME=
DELIVERY_WORDPRESS_APP_PASSWORD=
DELIVERY_WORDPRESS_TIMEOUT=30

# Astro delivery
DELIVERY_ASTRO_ENABLED=false
DELIVERY_ASTRO_NODE_BIN=node
DELIVERY_ASTRO_ADAPTER_DIST=
DELIVERY_ASTRO_CONTENT_DIR=
DELIVERY_ASTRO_PUBLIC_DIR=
DELIVERY_ASTRO_ASSETS_DIR=

# AI
AI_PROVIDER=google
GOOGLE_API_KEY=
GOOGLE_TRANSCRIPTION_MODEL=gemini-2.0-flash
GOOGLE_GENERATION_MODEL=gemini-2.0-flash
AI_DEFAULT_LANGUAGE=English
